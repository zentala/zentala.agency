---
import SectionHeader from '../primitives/sections/SectionHeader.astro'
import SectionGrid from '../primitives/sections/SectionGrid.astro'
import SectionContent from '../primitives/sections/SectionContent.astro'
import SectionCTA from '../primitives/sections/SectionCTA.astro'

type ListItem = {
  label?: string
  text: string
}

type Column = {
  title: string
  subtitle?: string
  headingAfterList?: string
  list?: ListItem[]
  paragraphs?: Array<{ strongLabel?: string; text: string; className?: string }>
}

interface Props {
  headline: string
  subhead: string
  columns: Column[]
  cta?: {
    href: string
    text: string
    icon?: string
    variant?: 'primary' | 'secondary' | 'outline'
  }
}

const { headline, subhead, columns, cta } = Astro.props
---

<div class="why-section">
  <SectionHeader
    headline={headline}
    subhead={subhead}
  />

  <SectionGrid columns={3}>
    {columns.map(col => (
      <SectionContent context="grid">
        <h3>{col.title}</h3>
        {col.subtitle ? <h4>{col.subtitle}</h4> : null}

        {col.list?.length ? (
          <ul>
            {col.list.map(item => (
              <li>
                {item.label ? <strong>{item.label}:</strong> : null} {item.text}
              </li>
            ))}
          </ul>
        ) : null}

        {col.headingAfterList ? <h4 class="mt-2">{col.headingAfterList}</h4> : null}

        {col.paragraphs?.length
          ? col.paragraphs.map(p => (
              <p class={p.className}>
                {p.strongLabel ? <strong>{p.strongLabel}:</strong> : null} {p.text}
              </p>
            ))
          : null}
      </SectionContent>
    ))}
  </SectionGrid>

  {cta ? (
    <SectionCTA
      href={cta.href}
      text={cta.text}
      icon={cta.icon}
      variant={cta.variant ?? 'secondary'}
    />
  ) : null}
</div>
