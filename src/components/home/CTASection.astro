---
import SectionHeader from '../primitives/sections/SectionHeader.astro'
import Button from '../Button.astro'

type CTAButton = {
  href: string
  text: string
  variant?: 'primary' | 'secondary' | 'outline'
  target?: string
  icon?: string
}

interface Props {
  headline: string
  subhead: string
  buttons: readonly CTAButton[]
  footerText?: string
}

const { headline, subhead, buttons, footerText } = Astro.props
---

<div class="cta-section">
  <SectionHeader
    headline={headline}
    subhead={subhead}
    align="center"
  />

  <div class="cta-buttons">
    {buttons.map(btn => (
      <Button
        href={btn.href}
        text={btn.text}
        variant={btn.variant ?? 'primary'}
        target={btn.target}
        icon={btn.icon}
      />
    ))}
  </div>

  {footerText ? <p class="cta-footer">{footerText}</p> : null}
</div>
