---
import SectionHeader from '../primitives/sections/SectionHeader.astro'
import Button from '../Button.astro'
---

<div class="cta-section">
  <SectionHeader
    headline="Let's Build Something From Scratch"
    subhead="Whether you're starting with just an idea or need specialized leadership for complex engineering - let's discuss how I can help."
    align="center"
  />

  <div class="cta-buttons">
    <Button
      href="https://cal.com/zentala"
      text="Schedule Discovery Call"
      variant="primary"
      target="_blank"
      icon="calendar"
    />
    <Button
      href="https://linkedin.com/in/zentala"
      text="Connect on LinkedIn"
      variant="secondary"
      target="_blank"
      icon="linkedin"
    />
    <Button
      href="/portfolio"
      text="Explore Portfolio"
      variant="outline"
      icon="folder"
    />
  </div>

  <p class="cta-footer">
    Based in Warsaw, Poland • Available for projects worldwide
  </p>
</div>
