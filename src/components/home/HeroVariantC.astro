---
import Logo from '../Logo.astro'
import Button from '../Button.astro'
---

<div class="hero-variant hero-variant-c">
  <div class="hero-content">
    <div class="hero-logo">
      <Logo type="full" color="#ffffff" width="200px" height="auto" />
    </div>

    <div class="hero-photo">
      <img
        src="https://cdn.zentala.io/images/avatar.jpg"
        alt="Paweł Żentała"
        class="photo-circular"
      />
    </div>

    <h1 class="hero-name">Paweł Żentała</h1>
    <h2 class="hero-title">I Build Innovation Teams From Scratch</h2>

    <p class="hero-description">
      For investors, founders, and companies starting complex engineering
      projects with no technical team - I am your hands-on CTO. I create
      technical vision, build working prototypes, assemble specialized teams,
      and transfer knowledge.
    </p>

    <p class="hero-experience">
      20+ years across IoT, robotics, full-stack development, DevOps, and UX.
      From vision to working prototype to production-ready team.
    </p>

    <div class="hero-cta">
      <Button
        href="https://cal.com/zentala"
        text="Schedule Discovery Call"
        variant="primary"
        target="_blank"
      />
      <Button href="/portfolio" text="View Portfolio" variant="secondary" />
    </div>
  </div>
</div>

