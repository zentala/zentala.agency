---
/**
 * BentoAboutMe
 *
 * Demonstrates the new Section Primitives system with:
 * - Asymmetric bento grid layout
 * - Mixed content types (text, images, quotes, CTAs)
 * - Custom column/row spans
 *
 */

import Section from '../primitives/sections/Section.astro'
import SectionHeader from '../primitives/sections/SectionHeader.astro'
import SectionBento from '../primitives/sections/SectionBento.astro'
import BentoCard from '../primitives/sections/BentoCard.astro'
import SectionContent from '../primitives/sections/SectionContent.astro'
import SectionImage from '../primitives/sections/SectionImage.astro'
import SectionBlockQuote from '../primitives/sections/SectionBlockQuote.astro'
import SectionCTA from '../primitives/sections/SectionCTA.astro'
---

<Section id="bento-about-me">
  <!-- <SectionHeader
    headline="Why Work With Me"
    subhead="A unique combination of technical depth and business understanding"
    interactive={true}
  /> -->

  <SectionBento rowHeight="0.8fr">
    <!-- Row 1-2: Col 1 - Business (1:2) (Was Col 4) -->
    <BentoCard colSpan={1} rowSpan={2} padding="sm">
      <SectionContent context="grid" prose={true}>
        <h3>Focus</h3>
        <p>Outcomes. Technical solutions that drive actual business results.</p>
        <p>Innovation. Cutting-edge solutions for complex problems.</p>
        <p>Fast Execution. Weeks, not months.</p>
      </SectionContent>
    </BentoCard>

    <!-- Row 1: Col 2 - Innovation (1:1) (Was Col 3) -->
    <BentoCard colSpan={1} rowSpan={1} padding="sm">
      <SectionContent context="grid" prose={true}>
        <h3>AI-powered development</h3>
        <p>
          Where others need specialized teams, I bring broad-horizon expertise
          across the entire technical stack - plus business strategy and user
          experience perspective.
        </p>
      </SectionContent>
    </BentoCard>

    <!-- Row 1: Col 3 - Years (1:1) (Was Col 2) -->
    <BentoCard colSpan={1} rowSpan={1} padding="sm">
      <SectionContent context="grid" prose={true}>
        <h3>20+ Years Experience</h3>
        <p>
          Startups and corporations. Management. User Experience and WebDesign.
          Marketing. Software Development. Robotics and Internet of Things.
        </p>
      </SectionContent>
    </BentoCard>

    <!-- Row 1-2: Col 4 - Avatar (1:2) (Was Col 1) -->
    <BentoCard colSpan={1} rowSpan={2} padding="none">
      <SectionImage
        src="https://cdn.zentala.io/images/avatar.jpg"
        alt="Paweł Żentała"
        aspectRatio="auto"
        objectFit="cover"
        hoverZoom={true}
        overlayPosition="bottom-right"
      >
        <h2 class="m-0 text-2xl font-light text-white opacity-50">
          Paweł Żentała
        </h2>
      </SectionImage>
    </BentoCard>

    <!-- Row 2-3: Col 2-3 - Electronics (2:2) -->
    <BentoCard colSpan={2} rowSpan={2} padding="none">
      <SectionImage
        src="https://images.unsplash.com/photo-1518770660439-4636190af475?w=800&h=600&fit=crop"
        alt="Electronics and technology"
        aspectRatio="auto"
        objectFit="cover"
        hoverZoom={true}
      />
    </BentoCard>

    <!-- Row 3-4: Col 1 - Workspace image (1:2) (Was Col 4) -->
    <BentoCard colSpan={1} rowSpan={2} padding="none">
      <SectionImage
        src="https://images.unsplash.com/photo-1504868584819-f8e8b4b6d7e3?w=800&h=600&fit=crop"
        alt="Technology workspace"
        aspectRatio="auto"
        objectFit="cover"
        hoverZoom={true}
      />
    </BentoCard>

    <!-- Row 3: Col 4 - Stack (1:1) (Was Col 1) -->
    <BentoCard colSpan={1} rowSpan={1} padding="sm">
      <SectionContent context="grid" prose={true}>
        <h1>Your Hands-On CTO for Innovation Projects</h1>
      </SectionContent>
    </BentoCard>

    <!-- Row 4: Col 2 - Generalist/Fast (1:1) (Was Col 3) -->
    <BentoCard colSpan={1} rowSpan={1} padding="sm">
      <SectionContent context="grid" prose={true}>
        <h3>Generalist</h3>
        <p>
          Where others need specialized teams, I bring broad-horizon expertise
          across the entire technical stack - plus business strategy and user
          experience perspective.
        </p>
      </SectionContent>
    </BentoCard>

    <!-- Row 4: Col 3-4 - Quote (2:1) (Was Col 1-2) -->
    <BentoCard colSpan={2} rowSpan={1} padding="sm">
      <SectionContent context="grid" prose={true}>
        <p>
          I build complex technology solutions from vision to working prototype
          - and assemble teams to scale them. With 20+ years across full-stack
          development, IoT, robotics, DevOps, management, and UX, I act as your
          technical co-founder until you have a team.
        </p>
      </SectionContent>
    </BentoCard>
  </SectionBento>
</Section>
