---
interface Props {
  id: string
  headline: string
  subhead: string
}

const { id, headline, subhead } = Astro.props
---

<div id={id} class="service-section">
  <div class="service-header">
    <h2 class="service-headline">{headline}</h2>
    <p class="service-subhead">{subhead}</p>
  </div>

  <div class="service-content">
    <slot />
  </div>
</div>
