---
/**
 * SectionContent - Universal content block
 *
 * Provides:
 * - Auto-adjusting padding based on context (full vs grid)
 * - Prose typography for text content
 * - Hover states with border mechanics
 *
 * Context modes:
 * - 'full': Large padding, max-width, centered (standalone)
 * - 'grid': Compact padding, full space (inside grid)
 * - 'auto': Auto-detect based on parent (TODO: implement)
 *
 * Usage:
 * <SectionContent context="full">
 *   <h3>Headline</h3>
 *   <p>Text content...</p>
 * </SectionContent>
 */

interface Props {
  context?: 'full' | 'grid' | 'auto'
  prose?: boolean
}

const { context = 'auto', prose = true } = Astro.props

// Auto-detect: default to 'full' for now (can enhance later)
const actualContext = context === 'auto' ? 'full' : context
---

<div
  class={`section-content section-content--${actualContext} ${prose ? 'section-content--prose' : ''}`}
>
  <div
    class={`section-content__body ${prose ? 'section-content__body--prose' : ''}`}
  >
    <slot />
  </div>
</div>

<style lang="scss">
  @use '../../../styles/variables' as *;

  .section-content {
    background: var(--section-content-bg, #000);
    transition: background 200ms;
    position: relative;
    z-index: 1;

    &:hover {
      z-index: 10; // Lift above siblings
    }
  }

  :global(.bento-card) .section-content {
    --section-content-bg: transparent;
  }

  :global(.bento-card:hover) .section-content {
    z-index: 10; // keep highlight above neighbors
  }

  // Full-width context: generous padding + max-width
  .section-content--full {
    max-width: 960px;
    margin: 0 auto;
    @include px-responsive('lg'); // 64→48→32→24→16px
    @include py-responsive('lg'); // 96→72→48→36→24px
  }

  // Grid context: compact padding, use available space
  .section-content--grid {
    // Much smaller padding for grid items (especially in bento)
    padding: 0.75rem 1rem; // ~12-16px

    @include medium-up {
      padding: 1rem 1.25rem; // ~16-20px
    }

    @include large-up {
      padding: 1.25rem 1.5rem; // ~20-24px on large screens
    }
  }

  // Prose styling for text content
  .section-content__body {
    width: 100%;
    color: #f8fafc;
  }

  .section-content--prose .section-content__body {
    max-width: 100%;

    :global(h1) {
      margin-top: 0;
      margin-bottom: 1.5rem;
      font-size: 44px;
      font-weight: 300;
      line-height: 1.1;
      color: #f8fafc;
    }

    :global(h2) {
      margin-top: 0;
      margin-bottom: 1rem;
      font-size: 32px;
      font-weight: 300;
      line-height: 1.1;
      color: #f8fafc;
    }

    :global(h3) {
      // Keep this as plain CSS (not @apply) because Tailwind @apply can be flaky in .astro <style>.
      // Requirement: all h3 headings inside the bento grid should be 24px.
      margin-top: 0;
      margin-bottom: 1rem;
      font-size: 24px;
      font-weight: 300;
      line-height: 1.1;
      color: #f8fafc;
    }

    :global(h4) {
      @apply mb-3 text-xl font-light;
      color: rgba(248, 250, 252, 0.95);
    }

    :global(h5) {
      @apply mb-2 text-lg font-light;
      color: rgba(248, 250, 252, 0.9);
    }

    :global(p) {
      @apply mb-4 text-base text-white/70 md:text-lg;

      &:last-child {
        margin-bottom: 0;
      }
    }

    :global(ul),
    :global(ol) {
      @apply mb-4 ml-6 text-base text-white/70 md:text-lg;

      li {
        @apply mb-2;

        strong {
          @apply text-white/90;
        }
      }
    }

    :global(ul) {
      list-style: disc;
    }

    :global(ol) {
      list-style: decimal;
    }

    :global(strong) {
      @apply font-normal text-white;
    }

    .value-statement {
      @apply mt-4 italic text-white/70;
    }

    .mt-2 {
      margin-top: 0.5rem;
    }
  }
</style>
