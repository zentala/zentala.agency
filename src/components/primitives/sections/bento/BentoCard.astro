---
/**
 * BentoCard - Universal card for bento grid layouts
 *
 * Provides:
 * - Custom column/row spans
 * - Flexible padding options
 * - Border mechanics handled by parent (SectionBento)
 * - Hover states
 * - Dev mode: Shows grid dimensions (col:row)
 *
 * Usage:
 * <BentoCard colSpan={2} rowSpan={1} padding="md">
 *   <SectionContent context="grid">...</SectionContent>
 * </BentoCard>
 */

interface Props {
  colSpan?: 1 | 2 | 3 | 4
  rowSpan?: 1 | 2 | 3
  padding?: 'none' | 'sm' | 'md' | 'lg'
  hoverState?: string
  class?: string
  [key: string]: any
}

const {
  colSpan = 1,
  rowSpan = 1,
  padding = 'md',
  hoverState,
  class: className,
  ...rest
} = Astro.props
const isDev = import.meta.env.DEV
---

<div
  class={`bento-card ${padding !== 'none' ? `bento-card--padding-${padding}` : ''} ${className || ''}`}
  style={`grid-column: span ${colSpan}; grid-row: span ${rowSpan};`}
  data-bento-hover={hoverState}
  {...rest}
>
  {
    isDev && (
      <div
        class="bento-card__dev-label"
        title={`Column span: ${colSpan}, Row span: ${rowSpan}`}
      >
        {colSpan}:{rowSpan}
      </div>
    )
  }
  <slot />
</div>

<style lang="scss">
  @use '../../../../styles/variables' as *;

  .bento-card {
    background: #000;
    transition: background 200ms;
    position: relative;

    &:hover {
      background: #111827;
    }

    // Dev mode label (top-right corner)
    &__dev-label {
      position: absolute;
      top: 4px;
      right: 4px;
      background: rgba(255, 255, 255, 0.1);
      color: rgba(255, 255, 255, 0.5);
      opacity: 0.5;
      font-size: 10px;
      font-weight: 600;
      padding: 2px 6px;
      border-radius: 3px;
      z-index: 100;
      pointer-events: none;
      font-family: monospace;
      line-height: 1;
    }

    // Padding variants - reduced for bento (1/3 of normal)
    &--padding-sm {
      padding: 0.5rem; // ~8px fixed for bento sm
    }

    &--padding-md {
      padding: 0.75rem 1rem; // ~12-16px for bento md

      @include medium-up {
        padding: 1rem 1.25rem; // ~16-20px
      }
    }

    &--padding-lg {
      padding: 1rem 1.25rem; // ~16-20px for bento lg

      @include medium-up {
        padding: 1.25rem 1.5rem; // ~20-24px
      }
    }
  }
</style>
