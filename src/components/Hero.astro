---
const { title, subtitle, eyebrow } = Astro.props
---

<section class="section-grid text-center text-white">
  <div class="container-padded py-responsive-lg">
    {
      eyebrow && (
        <p class="hero-eyebrow text-sm font-light tracking-wide text-white/55 sm:text-base">
          {eyebrow}
        </p>
      )
    }
    <h1
      class="text-4xl font-light leading-tight sm:text-5xl md:text-6xl xl:text-7xl 2xl:text-8xl"
      class:list={[eyebrow ? 'mt-3' : '']}
    >
      {title}
    </h1>
    <h2
      class="mt-6 text-xl font-light text-white/85 sm:text-2xl md:text-3xl xl:text-4xl"
    >
      {subtitle}
    </h2>
  </div>
</section>
