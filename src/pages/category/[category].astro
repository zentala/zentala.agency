---
import Layout from '../../layouts/Layout.astro'
import PostCard from '../../components/cards/PostCard.astro'
import { getCollection, getEntry, type CollectionEntry } from 'astro:content'

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(
    (post: CollectionEntry<'blog'>) =>
      import.meta.env.DEV || post.data.published !== false,
  )
  const categoryMap = new Map<
    string,
    { title: string; posts: CollectionEntry<'blog'>[] }
  >()

  posts.forEach((post) => {
    const title = post.data.category
    const slug = title.toLowerCase()
    const existing = categoryMap.get(slug)

    if (existing) {
      existing.posts.push(post)
    } else {
      categoryMap.set(slug, { title, posts: [post] })
    }
  })

  return Array.from(categoryMap.entries()).map(([category, data]) => ({
    params: { category },
    props: {
      posts: data.posts,
      displayTitle: data.title,
    },
  }))
}

interface Props {
  posts: CollectionEntry<'blog'>[]
}

const { category } = Astro.params as { category: string }
const { posts, displayTitle } = Astro.props as {
  posts: CollectionEntry<'blog'>[]
  displayTitle: string
}
const authorsCollection = await getCollection('authors')
const authors: any[] =
  authorsCollection && authorsCollection[0]
    ? (authorsCollection[0].data as any[])
    : []

// eslint-disable-next-line @typescript-eslint/ban-ts-comment
// @ts-expect-error - Astro content typing limitation for dynamic slug
const categoryDescriptionEntry = (await getEntry(
  'category-descriptions',
  category,
).catch(() => null)) as any | null

const Content = categoryDescriptionEntry
  ? (await categoryDescriptionEntry.render()).Content
  : null

const resolvedTitle =
  categoryDescriptionEntry?.data?.title || displayTitle || category
---

<Layout title={`Category: ${resolvedTitle}`}>
  <section class="section-full">
    <div class="container-bordered">
      <div class="padding-responsive-md border-b border-gray-800">
        <h1 class="text-4xl font-light text-white">
          Category: {resolvedTitle}
        </h1>
        {
          categoryDescriptionEntry ? (
            Content && (
              <div class="category-description-content prose prose-invert mt-4 max-w-none text-gray-300 prose-strong:text-white">
                <Content />
              </div>
            )
          ) : (
            <div class="category-description-content prose prose-invert mt-4 max-w-none text-gray-300 prose-strong:text-white">
              Category description not found.
            </div>
          )
        }
      </div>
      <div class="cards-grid">
        {
          posts.map((post) => {
            const author = authors.find((a: any) => a.slug === post.data.author)
            return (
              <PostCard
                title={post.data.title}
                date={post.data.date}
                category={post.data.category}
                imageUrl={post.data.imageUrl}
                excerpt={post.data.excerpt}
                authorName={author?.name}
                authorAvatar={author?.avatar}
                authorRole={post.data.authorRole || author?.role}
                link={`/blog/${post.slug}`}
              />
            )
          })
        }
      </div>
    </div>
  </section>
</Layout>

<style lang="postcss" is:global>
  .category-description-content p,
  .category-description-content li {
    @apply text-xl;
  }
</style>
