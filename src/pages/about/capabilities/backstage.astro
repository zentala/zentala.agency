---
import Layout from '../../../layouts/Layout.astro'
import Hero from '../../../components/Hero.astro'
import Section from '../../../components/primitives/sections/Section.astro'
import SectionHeader from '../../../components/primitives/sections/SectionHeader.astro'
import SectionGrid from '../../../components/primitives/sections/SectionGrid.astro'
import SectionContent from '../../../components/primitives/sections/SectionContent.astro'
import SectionCTA from '../../../components/primitives/sections/SectionCTA.astro'
import CardBackgroundIcon from '../../../components/primitives/CardBackgroundIcon.astro'
import CTA from '../../../components/CTA.astro'
import Button from '../../../components/Button.astro'

const techStack = [
  'Backstage',
  'TypeScript',
  'Node.js',
  'React',
  'MCP Server',
  'Docker',
  'Kubernetes',
  'PostgreSQL',
]

const CAL_URL = 'https://cal.com/zentala'
const DEVSTAGE_URL = 'https://devstage.io'
const LINKEDIN_URL = 'https://linkedin.com/in/zentala'

const heroProps = {
  eyebrow: 'DevStage by Żentała Innovation Agency',
  title: 'Extend Backstage. Ship What Your Team Can’t.',
  subtitle:
    'Backstage and DevEx specialists. Fast implementations, data integrations, consulting, contracting & body leasing. Enterprise experience, no vendor lock-in.',
}

const developmentServices = [
  {
    name: 'Custom Plugin Development',
    icon: 'ph:rocket-launch-thin',
    description:
      'Bespoke plugins that solve your specific workflow challenges — from simple automations to complex full-stack features.',
    features: [
      'API integrations with your tech stack',
      'Custom UI components & workflows',
      'Entity pages & homepage widgets',
      'Real-time data synchronization',
    ],
  },
  {
    name: 'Processors Engineering',
    icon: 'ph:gear-six-thin',
    description:
      'Pre/post processors that transform how Backstage catalogs and processes your resources.',
    features: [
      'Custom entity processors',
      'Non-standard resource cataloging',
      'Automated discovery & ingestion',
      'Data transformation pipelines',
    ],
  },
  {
    name: 'Theme & UI Customization',
    icon: 'ph:palette-thin',
    description:
      'Transform Backstage into a branded experience that developers love to use.',
    features: [
      'Custom corporate theming',
      'Portal branding — logo, naming, taglines',
      'Dark mode optimization',
      'Custom navigation & layouts',
    ],
  },
]

const consultingServices = [
  {
    name: 'Strategic DevEx Consulting',
    icon: 'ph:lightbulb-thin',
    description:
      'Long-term strategic guidance to architect and implement your Backstage ecosystem.',
    features: [
      'DevEx strategy & roadmaps',
      'Platform architecture design',
      'Integration strategy planning',
      'Team skill development planning',
    ],
  },
  {
    name: 'AI Chat & MCP',
    icon: 'ph:robot-thin',
    description:
      'AI-powered chatbot integrated with Backstage data and actions. Embedded chat or MCP Server integration.',
    features: [
      'Chat with catalog data',
      'Trigger self-service actions',
      'MCP Server integration',
      'Custom AI plugin development',
    ],
  },
  {
    name: 'Security SLA',
    icon: 'ph:shield-check-thin',
    description:
      'Keep your enterprise Backstage patched within 48 hours of every upstream security release.',
    features: [
      '48h security update SLA',
      'Continuous upstream tracking',
      'Entry audit of current configuration',
      'Patch coordination with your team',
    ],
  },
  {
    name: 'Developer Education',
    icon: 'ph:chalkboard-teacher-thin',
    description:
      'Knowledge transfer built into every engagement — your team learns as we work.',
    features: [
      'Team workshops & training',
      'Plugin development courses',
      'Documentation & runbooks',
      'Paired coding sessions',
    ],
  },
]

const processSteps = [
  {
    n: '01',
    icon: 'ph:magnifying-glass-thin',
    title: 'Free Consultation',
    body: '30-minute call to understand your Backstage needs and challenges. We assess fit and discuss potential approaches.',
  },
  {
    n: '02',
    icon: 'ph:list-checks-thin',
    title: 'Technical Discovery',
    body: 'We map your integration landscape, understand your organization, and define success metrics. Results in a clear engagement plan.',
  },
  {
    n: '03',
    icon: 'ph:hammer-thin',
    title: 'Delivery & Iteration',
    body: 'Expert hours focused on your specific work. Pay for results, scale up or down as needed. Agile sprints with fast feedback loops.',
  },
  {
    n: '04',
    icon: 'ph:handshake-thin',
    title: 'Handover & Support',
    body: 'You own everything we build. Full source code, documentation, knowledge transfer. Continue independently or with ongoing support.',
  },
]

const engagementModels = [
  {
    name: 'Project Sprints',
    icon: 'ph:lightning-thin',
    description:
      'Intensive development sprints for specific features — custom plugins, AI integrations, processor development — with measurable impact and a fixed scope.',
    features: [
      'Fixed-scope, outcome-based',
      'Specific feature delivery',
      'Team training included',
      'Documentation & handover',
    ],
  },
  {
    name: 'Extended Engagement',
    icon: 'ph:infinity-thin',
    description:
      'A dedicated DevEx team embedded in your project for months. We join your standups, architect solutions, ship complex features, and mentor your team throughout.',
    features: [
      'Daily involvement in your project',
      'Direct hands-on development',
      'Architecture & strategic planning',
      'Continuous knowledge transfer',
    ],
  },
  {
    name: 'Contracting & Body Leasing',
    icon: 'ph:users-three-thin',
    description:
      'Hire a Backstage contractor — or a full team — to plug into your project. You direct the work, we deliver hours. Paweł works contracting himself, and we have a vetted network of Backstage specialists ready to deploy.',
    features: [
      'Single contractor or full team',
      'Vetted Backstage specialists from our network',
      'Monthly retainer or hourly billing',
      'You direct, we execute',
    ],
  },
]

const whyExternalConsultant = [
  'Fresh perspective on your challenges',
  'Hands-on builders who code alongside your team',
  'Latest DevEx trends, Backstage solutions, and AI innovations',
  'Vetted contractor network for staff augmentation',
  'Objective assessment of your needs',
  'No internal politics or bias',
  'Knowledge transfer built into every engagement',
  'Accelerate your roadmap by months',
]

const faqs = [
  {
    q: 'How do we start working together?',
    a: 'A free 30-minute consultation. No commitment — just a conversation about your Backstage needs and challenges, and an honest assessment of fit.',
  },
  {
    q: 'Do I need to commit to a long-term contract?',
    a: 'No. Pay for results, scale up or down as needed. Agile sprints with fast feedback loops, no minimum term.',
  },
  {
    q: 'How is this different from Roadie or Port.io?',
    a: 'Hosted services lock you into their stack. We deploy Backstage in your infrastructure — full source code, no vendor lock-in. You own everything.',
  },
  {
    q: 'What if we already have Backstage deployed?',
    a: 'We come in to extend it: custom plugins, processors, data ingestion, security updates. An entry audit of your current configuration is included.',
  },
  {
    q: 'Can you provide contractors or help us build an internal DevEx team?',
    a: 'Both. We can plug a contractor — or a full team — into your project as staff augmentation. Or run a project that builds capabilities into your team.',
  },
  {
    q: 'Do you work remotely or onsite?',
    a: 'Remote-first, CET timezone, working with clients worldwide. Onsite kickoffs within the EU possible by arrangement.',
  },
]

const finalCtaButtons = [
  {
    href: CAL_URL,
    text: 'Schedule Discovery Call',
    variant: 'light',
    target: '_blank',
    icon: 'calendar',
  },
  {
    href: DEVSTAGE_URL,
    text: 'Visit DevStage.io',
    variant: 'secondary',
    target: '_blank',
    icon: 'external-link',
  },
  {
    href: LINKEDIN_URL,
    text: 'Connect on LinkedIn',
    variant: 'secondary',
    target: '_blank',
    icon: 'linkedin',
  },
] as const

const finalCtaFooter = [
  { icon: 'map-pin', text: 'Warsaw, Poland · CET timezone' },
  { icon: 'globe', text: 'Working with clients worldwide' },
] as const
---

<Layout
  title="Backstage Consulting & Plugin Development — DevStage.io"
  description="Custom Backstage plugins, processors, and strategic DevEx consulting for platform teams running Backstage at scale. Part of DevStage.io."
>
  <Hero {...heroProps} />

  <!-- Tech Stack -->
  <div class="tech-stack">
    <div class="container-bordered">
      <div class="tech-stack__inner">
        <span class="tech-stack__label">Stack</span>
        <ul class="tech-stack__list">
          {techStack.map((tech) => <li>{tech}</li>)}
        </ul>
      </div>
    </div>
  </div>

  <!-- Development Services -->
  <Section id="development">
    <SectionHeader
      eyebrow="Development services"
      icon="ph:wrench-thin"
      headline="What I build"
      subhead="Hands-on engineering across the Backstage stack."
    />
    <SectionGrid columns={3}>
      {
        developmentServices.map((service) => (
          <SectionContent context="grid" prose={false}>
            <CardBackgroundIcon icon={service.icon} />
            <div class="bs-card">
              <h3 class="bs-card__title">{service.name}</h3>
              <p class="bs-card__desc">{service.description}</p>
              <ul class="bs-list">
                {service.features.map((feature) => (
                  <li>
                    <span class="bs-list__check">✓</span>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          </SectionContent>
        ))
      }
    </SectionGrid>
  </Section>

  <!-- Strategic Consulting -->
  <Section id="consulting">
    <SectionHeader
      eyebrow="Strategic consulting"
      icon="ph:lightbulb-filament-thin"
      headline="What I advise on"
      subhead="Strategy, AI, security, and education — turning Backstage into an org-wide platform."
    />
    <SectionGrid columns={2}>
      {
        consultingServices.map((service) => (
          <SectionContent context="grid" prose={false}>
            <CardBackgroundIcon icon={service.icon} />
            <div class="bs-card">
              <h3 class="bs-card__title">{service.name}</h3>
              <p class="bs-card__desc">{service.description}</p>
              <ul class="bs-list">
                {service.features.map((feature) => (
                  <li>
                    <span class="bs-list__check">✓</span>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          </SectionContent>
        ))
      }
    </SectionGrid>
  </Section>

  <!-- DevStage.io banner -->
  <Section id="devstage" class="bs-devstage">
    <div class="bs-devstage__inner">
      <CardBackgroundIcon icon="ph:plugs-connected-thin" />
      <div class="bs-devstage__content">
        <img
          src="/devstage-logo-light.svg"
          alt="DevStage logo"
          class="bs-devstage__logo"
          width="72"
          height="66"
        />
        <span class="bs-devstage__eyebrow">Our Backstage practice</span>
        <h2 class="bs-devstage__title">
          Backstage Specialists at <span class="bs-devstage__brand"
            >DevStage.io</span
          >
        </h2>
        <p class="bs-devstage__body">
          DevStage is our dedicated Backstage practice inside Żentała Innovation
          Agency — fast implementations, data integrations, and consulting with
          enterprise experience and no vendor lock-in.
        </p>
      </div>
    </div>
    <ul class="bs-devstage__stats">
      <li>
        <span class="bs-devstage__stat-num">3</span>
        <span class="bs-devstage__stat-label">years in Backstage</span>
      </li>
      <li>
        <span class="bs-devstage__stat-num">4</span>
        <span class="bs-devstage__stat-label">enterprise IDP implementations</span>
      </li>
      <li>
        <span class="bs-devstage__stat-num">1</span>
        <span class="bs-devstage__stat-label">open source plugin released</span>
      </li>
      <li>
        <span class="bs-devstage__stat-num">5</span>
        <span class="bs-devstage__stat-label">specialists with various profiles</span>
      </li>
    </ul>
    <div class="bs-devstage__cta">
      <Button
        href={DEVSTAGE_URL}
        text="Visit DevStage.io"
        target="_blank"
        variant="secondary"
        icon="external-link"
      />
    </div>
  </Section>

  <!-- How we work -->
  <Section id="process">
    <SectionHeader
      eyebrow="Engagement process"
      icon="ph:flow-arrow-thin"
      headline="How we work"
      subhead="A predictable four-step path from first call to your team owning the work."
    />
    <SectionGrid columns={2}>
      {
        processSteps.map((step) => (
          <SectionContent context="grid" prose={false}>
            <CardBackgroundIcon icon={step.icon} />
            <span class="bs-step__num">{step.n}</span>
            <div class="bs-card bs-card--step">
              <h3 class="bs-card__title">{step.title}</h3>
              <p class="bs-card__desc">{step.body}</p>
            </div>
          </SectionContent>
        ))
      }
    </SectionGrid>
  </Section>

  <!-- Engagement Models -->
  <Section id="engagement">
    <SectionHeader
      eyebrow="Working together"
      icon="ph:handshake-thin"
      headline="Engagement models"
      subhead="Three ways to work together — pick the format that matches your need."
    />
    <SectionGrid columns={3}>
      {
        engagementModels.map((model) => (
          <SectionContent context="grid" prose={false}>
            <CardBackgroundIcon icon={model.icon} />
            <div class="bs-card">
              <h3 class="bs-card__title">{model.name}</h3>
              <p class="bs-card__desc">{model.description}</p>
              <ul class="bs-list">
                {model.features.map((feature) => (
                  <li>
                    <span class="bs-list__check">✓</span>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          </SectionContent>
        ))
      }
    </SectionGrid>
  </Section>

  <!-- About -->
  <Section id="about">
    <SectionHeader
      eyebrow="About"
      icon="ph:user-circle-thin"
      headline="Your Backstage partner"
      subhead="20+ years bridging technology and human communication — from robotics and IoT to developer portals."
    />
    <SectionGrid columns={2}>
      <SectionContent context="grid" prose={false}>
        <div class="bs-card">
          <h3 class="bs-card__title bs-card__title--lg">
            Led by a hands-on DevEx engineer
          </h3>
          <p class="bs-about__lead">
            DevStage is led by <strong>Paweł Żentała</strong>, a creative DevEx
            engineer who codes alongside the team. Companies bring us in as
            their <strong>external Backstage practice</strong> for months-long
            engagements — we become part of your team, architect solutions,
            build complex features, and elevate the entire developer experience.
          </p>
          <p class="bs-about__body">
            Our approach focuses on
            <strong>inspiring and educating</strong> your team while handling the
            most innovative and challenging development work. We help you build
            capabilities, not dependencies.
          </p>
          <div class="bs-about__divider"></div>
          <h4 class="bs-about__subhead">What we deliver</h4>
          <p class="bs-about__body">
            Developer portals teams actually want to use — strategic guidance,
            innovative solutions, hands-on development, and knowledge transfer
            that empowers your developers long after we’re gone.
          </p>
        </div>
      </SectionContent>
      <SectionContent context="grid" prose={false}>
        <div class="bs-card">
          <h3 class="bs-card__title">Why hire an external Backstage expert</h3>
          <ul class="bs-list">
            {
              whyExternalConsultant.map((benefit) => (
                <li>
                  <span class="bs-list__check">✓</span>
                  {benefit}
                </li>
              ))
            }
          </ul>
        </div>
      </SectionContent>
    </SectionGrid>
  </Section>

  <!-- FAQ -->
  <Section id="faq">
    <SectionHeader
      eyebrow="FAQ"
      icon="ph:question-thin"
      headline="Common questions"
      subhead="What teams typically ask before booking the consultation."
    />
    <ul class="bs-faq-list">
      {
        faqs.map((item, idx) => (
          <li class="bs-faq-item">
            <span class="bs-faq-item__num">
              Q.{String(idx + 1).padStart(2, '0')}
            </span>
            <div class="bs-faq-item__body">
              <h3 class="bs-faq-item__q">{item.q}</h3>
              <p class="bs-faq-item__a">{item.a}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </Section>

  <!-- Final CTA -->
  <Section id="cta">
    <CTA
      headline="Ready to extend your Backstage?"
      subhead="Start with a free 30-minute consultation — no slides, no pitch, just your situation and what would unblock it."
      buttons={finalCtaButtons}
      footerItems={finalCtaFooter}
    />
  </Section>
</Layout>

<style lang="scss">
  /* Restore proper card padding (matches CardContainer used elsewhere on site).
     Need !important to beat SectionContent's own scoped styles. */
  :global(.section-grid-wrapper > .section-content) {
    padding: 4rem !important;
  }

  @media (max-width: 1440px) {
    :global(.section-grid-wrapper > .section-content) {
      padding: 3rem !important;
    }
  }

  @media (max-width: 1000px) {
    :global(.section-grid-wrapper > .section-content) {
      padding: 2rem !important;
    }
  }

  @media (max-width: 770px) {
    :global(.section-grid-wrapper > .section-content) {
      padding: 1.5rem !important;
    }
  }

  @media (max-width: 480px) {
    :global(.section-grid-wrapper > .section-content) {
      padding: 1rem !important;
    }
  }

  /* Hover behavior is handled by SectionGrid (z-index + border-color).
     Do not add margin shifts here — they cause content to jump on hover. */

  .bs-card {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .bs-card--step {
    gap: 0.5rem;
  }

  .bs-card--full {
    width: 100%;
  }

  .bs-card__step {
    color: rgba(255, 255, 255, 0.3);
    font-size: 0.875rem;
    letter-spacing: 0.2em;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .bs-card__title {
    color: #fff;
    font-size: 1.875rem; /* text-3xl — matches card-title-large */
    font-weight: 300;
    line-height: 1.2;
    margin-bottom: 1.25rem;
  }

  .bs-card__title--lg {
    font-size: 2rem;
  }

  .bs-card__pain {
    color: rgba(255, 255, 255, 0.85);
    font-style: italic;
    font-size: 1rem;
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .bs-card__fix {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .bs-card__desc {
    color: rgba(255, 255, 255, 0.75);
    font-size: 1.125rem; /* text-lg — matches card-content */
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .bs-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;

    li {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      color: rgba(255, 255, 255, 0.75);
      font-size: 1rem; /* text-base */
      line-height: 1.5;
    }
  }

  .bs-list--two-col {
    @media (min-width: 770px) {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.625rem 2rem;
    }
  }

  .bs-list__check {
    color: rgba(255, 255, 255, 0.45);
    font-weight: 400;
    flex-shrink: 0;
    transition: color 200ms ease-in-out;
  }

  :global(.section-grid):hover .bs-list__check,
  :global(.cards-grid) > *:hover .bs-list__check {
    color: #fff;
  }

  .bs-about__lead {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.125rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .bs-about__body {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.125rem; /* text-lg */
    line-height: 1.6;
  }

  .bs-about__divider {
    width: 3rem;
    height: 1px;
    background: #1f2937;
    margin: 2rem 0;
  }

  .bs-about__subhead {
    color: #fff;
    font-size: 1.25rem;
    font-weight: 300;
    line-height: 1.2;
    margin: 0 0 1rem;
  }

  /* FAQ — accordion-style single column list, always expanded */
  .bs-faq-list {
    list-style: none;
    padding: 0;
    margin: -1px 0 0; /* overlap previous element's bottom border */
    border-top: 1px solid #1f2937;
  }

  .bs-faq-item {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 2rem;
    align-items: start;
    padding: 2.25rem 1rem 2.25rem 4rem;
    background: #000;
    border-bottom: 1px solid #1f2937;
    position: relative;
    z-index: 1;
    transition: all 200ms ease-in-out;

    @media (max-width: 1440px) {
      padding: 2rem 0.75rem 2rem 3rem;
      grid-template-columns: 5.5rem 1fr;
    }

    @media (max-width: 1000px) {
      padding: 1.75rem 0.5rem 1.75rem 2rem;
      grid-template-columns: 5rem 1fr;
      gap: 1.5rem;
    }

    @media (max-width: 770px) {
      padding: 1.5rem 0.5rem 1.5rem 1.5rem;
      grid-template-columns: 3.5rem 1fr;
      gap: 1.25rem;
    }

    @media (max-width: 480px) {
      padding: 1.25rem 0.5rem 1.25rem 1rem;
      grid-template-columns: 3rem 1fr;
      gap: 1rem;
    }

    &:hover {
      z-index: 10;
      background: #111827;
      border-color: #374151;
    }
  }

  .bs-faq-item__num {
    color: rgba(255, 255, 255, 0.35);
    font-size: 2.75rem;
    font-weight: 200;
    line-height: 1;
    letter-spacing: -0.02em;
    font-variation-settings: 'wght' 100;

    @media (max-width: 770px) {
      font-size: 2rem;
    }
  }

  .bs-faq-item__body {
    min-width: 0; /* allow text wrapping inside grid */
  }

  .bs-faq-item__q {
    color: #fff;
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.35;
    margin: 0 0 0.5rem;

    @media (max-width: 770px) {
      font-size: 1.125rem;
    }
  }

  .bs-faq-item__a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
  }

  /* DevStage.io banner */
  .bs-devstage {
    :global(.section-grid) {
      background: #000;
    }
  }

  .bs-devstage__inner {
    position: relative;
    overflow: hidden;
    padding: 4rem;

    @media (max-width: 1000px) {
      padding: 3rem 2rem;
    }

    @media (max-width: 770px) {
      padding: 2rem 1.5rem;
    }
  }

  .bs-devstage__content {
    position: relative;
    z-index: 1;
    max-width: 56rem;
  }

  .bs-devstage__eyebrow {
    display: inline-block;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 400;
    margin-bottom: 1.25rem;
  }

  .bs-devstage__title {
    color: #fff;
    font-size: 2.25rem;
    font-weight: 300;
    line-height: 1.2;
    margin-bottom: 1.5rem;

    @media (min-width: 1000px) {
      font-size: 2.75rem;
    }
  }

  .bs-devstage__brand {
    color: #fff;
    font-weight: 400;
  }

  .bs-devstage__body {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.125rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .bs-devstage__logo {
    display: block;
    width: 72px;
    height: auto;
    margin-bottom: 1.5rem;
