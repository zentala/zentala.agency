---
import SectionHeader from '../../components/primitives/sections/SectionHeader.astro'
import Button from '../../components/Button.astro'
import { Icon } from 'astro-icon/components'

type CTAButton = {
  href: string
  text: string
  variant?: 'primary' | 'secondary' | 'outline'
  target?: string
  icon?: string
}

interface Props {
  headline: string
  subhead: string
  buttons: readonly CTAButton[]
  footerText?: string
}

const { headline, subhead, buttons, footerText } = Astro.props
---

<div class="cta-section">
  <SectionHeader
    headline={headline}
    subhead={subhead}
    align="center"
  />

  <div class="cta-buttons">
    {buttons.map(btn => (
      <Button
        href={btn.href}
        text={btn.text}
        variant={btn.variant ?? 'primary'}
        target={btn.target}
        icon={btn.icon}
      />
    ))}
  </div>

  {footerText ? (
    <p class="cta-footer">
      <span class="inline-flex items-center">
        <Icon name="lucide:map-pin" class="mr-2 h-4 w-4 text-blue-500" />
        <span>{footerText}</span>
      </span>
      <span class="mx-3 opacity-20">•</span>
      <span class="inline-flex items-center">
        <Icon name="lucide:globe" class="mr-2 h-4 w-4 text-blue-500" />
        <span>Available for projects worldwide</span>
      </span>
    </p>
  ) : null}
</div>


