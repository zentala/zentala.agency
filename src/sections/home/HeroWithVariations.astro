---
import Hero from './Hero.astro'

type VariantKey = 'A' | 'B' | 'C' | 'D' | 'E'

type HeroVariantConfig = {
  componentProps: Record<string, any>
}

interface Props {
  variants: Record<VariantKey, HeroVariantConfig>
  defaultVariant?: VariantKey
}

const { variants, defaultVariant = 'A' } = Astro.props
---

<div class="hero-section">
  {Object.entries(variants).map(([key, config]) => (
    <div
      data-variant={key}
      class={`hero-variant-wrapper ${key === defaultVariant ? 'hero-variant-active' : 'hero-variant-hidden'}`}
    >
      <Hero {...(config.componentProps as any)} />
    </div>
  ))}
</div>

<style>
  .hero-variant-hidden {
    display: none;
  }

  .hero-variant-active {
    display: block;
  }
</style>

<script>
  // Client-side variant switching based on URL parameter
  function switchHeroVariant() {
    const urlParams = new URLSearchParams(window.location.search)
    const variant = urlParams.get('hero')?.toUpperCase() || 'A'
    const validVariants = ['A', 'B', 'C', 'D', 'E']
    const activeVariant = validVariants.includes(variant) ? variant : 'A'

    // Hide all variants
    document.querySelectorAll('.hero-variant-wrapper').forEach(el => {
      el.classList.remove('hero-variant-active')
      el.classList.add('hero-variant-hidden')
    })

    // Show active variant
    const activeEl = document.querySelector(`[data-variant="${activeVariant}"]`)
    if (activeEl) {
      activeEl.classList.remove('hero-variant-hidden')
      activeEl.classList.add('hero-variant-active')
    }
  }

  // Run on load and on URL change
  switchHeroVariant()
  window.addEventListener('popstate', switchHeroVariant)
</script>


